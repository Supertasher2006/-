def fetch_random_question():
    response = requests.get(API_URL)
    if response.status_code == 200:
        data = response.json()
        if data:
            num_elements = len(data)
            # Шаг 2: Генерируем случайное число от 0 до num_elements - 1
            random_index = random.randrange(num_elements)
            # Шаг 3: Извлекаем элемент по этому индексу
